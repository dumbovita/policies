        "Locked": false
      },
      "Translations": {
        "Value": "blocked",
        "Locked": false
      },
      "PDFAltText": {
        "Value": "blocked",
        "Locked": false
      },
      "SidebarChatbot": {
        "Value": "blocked",
        "Locked": false
      },
      "SmartTabGroups": {
        "Value": "blocked",
        "Locked": false
